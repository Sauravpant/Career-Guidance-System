generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TYPE {
  GLOBAL
  PHASE
}

model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  education  String
  experience Int

  skills String[]

  avatarUrl String?
  bannerUrl String?

  createdAt DateTime @default(now())

  recommendations Recommendation[]
  roadmaps        Roadmap[]
  phaseProgress   PhaseProgress[]
  projects        Project[]
  resources       Resource[]

  @@index([email])
}

model Career {
  id String @id @default(cuid())

  name           String   @unique
  requiredSkills String[]

  createdAt DateTime @default(now())

  roadmaps Roadmap[]
}

model Recommendation {
  id String @id @default(cuid())

  userId String

  bestCareer String
  confidence Float

  top3 Json

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Roadmap {
  id String @id @default(cuid())

  userId   String
  careerId String

  title String

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  career Career @relation(fields: [careerId], references: [id])

  phases RoadmapPhase[]
}

model RoadmapPhase {
  id String @id @default(cuid())

  roadmapId String

  phaseNumber Int
  title       String
  description String

  topics Json

  createdAt DateTime @default(now())

  roadmap Roadmap @relation(fields: [roadmapId], references: [id])

  progress  PhaseProgress[]
  projects  Project[]
  resources Resource[]
}

model PhaseProgress {
  id String @id @default(cuid())

  userId  String
  phaseId String

  completed Boolean @default(false)

  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id])
  phase RoadmapPhase @relation(fields: [phaseId], references: [id])

  @@unique([userId, phaseId])
}

model Project {
  id String @id @default(cuid())

  userId  String
  phaseId String?

  title       String
  description String
  steps       String

  type TYPE

  createdAt DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id])
  phase RoadmapPhase? @relation(fields: [phaseId], references: [id])
}

model Resource {
  id String @id @default(cuid())

  userId  String
  phaseId String?

  title       String
  description String
  url         String
  type        TYPE

  createdAt DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id])
  phase RoadmapPhase? @relation(fields: [phaseId], references: [id])
}
